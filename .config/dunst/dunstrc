[global]
    background = "#121212cc";

    ### Display ###
    origin = top-right

    # Perbaikan syntax baru
    offset = (20, 20)
    width = 320
    height = (0, 110)
    
    mouse_left_click = do_action, close_current

    notification_limit = 5
    
    # Progress bar ala macOS (tipis di bawah)
    progress_bar = true
    progress_bar_height = 2
    progress_bar_frame_width = 0
    
    ### Design ###
    # macOS punya border yang sangat tipis dan halus
    frame_width = 1
    corner_radius = 10  # macOS Sequoia/Tahoe lebih membulat
    
    padding = 18
    horizontal_padding = 18
    icon_position = left
    min_icon_size = 40
    max_icon_size = 50
    
    # Font Apple Style
    font = Inter 10
    line_height = 3
    format = "<b>%s</b>\n%b"
    
    # Border warna abu-abu gelap transparan (Glass look)
    frame_color = "#414141"
    separator_color = "frame"

[urgency_low]
    # Warna background macOS Dark Mode (Semi-Transparent Black-Grey)
    # background = "#1a1a1acc" 
    foreground = "#ffffff"
    timeout = 5

[urgency_normal]
    # "cc" di belakang hex itu buat transparansi (Alpha channel)
    # background = "#1a1a1acc"
    foreground = "#ffffff"
    timeout = 7

[urgency_critical]
    # background = "#1a1a1acc"
    foreground = "#ffffff"
    frame_color = "#ff5555"
    timeout = 0

[osd]
    appname = "osd"
    # Origin dkk dihapus karena udah ikut [global]
    icon_position = off
    min_icon_size = 32
    max_icon_size = 32
    format = "<b>%s</b>"
   
    highlight = "#ffffff"  # Putih ala macOS
    timeout = 2